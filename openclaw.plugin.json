{
  "id": "open-lesson",
  "name": "openLesson",
  "description": "openLesson tutoring platform integration - generate learning plans, start guided tutoring sessions, and analyze audio for reasoning gaps",
  "version": "1.0.0",
  "author": "openLesson",
  "homepage": "https://www.openlesson.academy",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiKey": {
        "type": "string",
        "description": "openLesson API key for authentication"
      },
      "baseUrl": {
        "type": "string",
        "default": "https://www.openlesson.academy",
        "description": "API base URL (default: https://www.openlesson.academy)"
      }
    },
    "required": ["apiKey"]
  },
  "uiHints": {
    "apiKey": {
      "label": "API Key",
      "sensitive": true,
      "placeholder": "sk_..."
    },
    "baseUrl": {
      "label": "API Base URL",
      "placeholder": "https://www.openlesson.academy"
    }
  }
}
